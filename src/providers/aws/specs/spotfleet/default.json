{
  "IamFleetRole": "{{ fleet_role }}",
  "AllocationStrategy": "{{ allocation_strategy }}",
  "TargetCapacity": {{ target_capacity }}{% if is_heterogeneous %},
  "OnDemandTargetCapacity": {{ on_demand_count }}{% endif %},
  "Type": "{{ fleet_type | default('request') }}",
  "LaunchTemplateConfigs": [
    {
      "LaunchTemplateSpecification": {
        "LaunchTemplateId": "{{ launch_template_id }}",
        "Version": "{{ launch_template_version }}"
      }{% if has_abis or has_overrides %},
      "Overrides": [
        {% if has_abis %}
        {"InstanceRequirements": {{ abis_instance_requirements | tojson }}}
        {% else %}
        {% for override in instance_overrides %}
        {
          "InstanceType": "{{ override.instance_type }}"{% if override.subnet_id %},
          "SubnetId": "{{ override.subnet_id }}"{% endif %}{% if override.weighted_capacity %},
          "WeightedCapacity": {{ override.weighted_capacity }}{% endif %}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
        {% endif %}
      ]{% endif %}
    }
  ],
  "InstanceInterruptionBehavior": "{{ instance_interruption_behavior }}",
  "ReplaceUnhealthyInstances": {{ replace_unhealthy_instances | tojson }},
  "TagSpecifications": [
    {
      "ResourceType": "spot-fleet-request",
      "Tags": [
        {"Key": "Name", "Value": "{{ fleet_name }}"}
        {%- for tag in base_tags %},
        {"Key": "{{ tag.key }}", "Value": "{{ tag.value }}"}
        {%- endfor %}
        {%- for tag in custom_tags %},
        {"Key": "{{ tag.key }}", "Value": "{{ tag.value }}"}
        {%- endfor %}
      ]
    }
  ]
}
