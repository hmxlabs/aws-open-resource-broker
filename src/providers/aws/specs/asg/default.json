{
  "AutoScalingGroupName": "{{ asg_name }}",
  {% if has_abis or spot_count > 0 %}"MixedInstancesPolicy": {
    "LaunchTemplate": {
      "LaunchTemplateSpecification": {
        "LaunchTemplateId": "{{ launch_template_id }}",
        "Version": "{{ launch_template_version }}"
      }{% if has_abis %},
      "Overrides": [
        {
          "InstanceRequirements": {{ abis_instance_requirements | tojson }}
        }
      ]{% endif %}
    }{% if spot_count > 0 %},
    "InstancesDistribution": {
      "OnDemandBaseCapacity": 0,
      "OnDemandPercentageAboveBaseCapacity": {{ percent_on_demand }}
    }{% endif %}
  }{% else %}"LaunchTemplate": {
    "LaunchTemplateId": "{{ launch_template_id }}",
    "Version": "{{ launch_template_version }}"
  }{% endif %},
  "MinSize": {{ min_size }},
  "MaxSize": {{ max_size }},
  "DesiredCapacity": {{ desired_capacity }},
  "DefaultCooldown": {{ default_cooldown }},
  "HealthCheckType": "{{ health_check_type }}",
  "HealthCheckGracePeriod": {{ health_check_grace_period }}{% if has_subnets %},
  "VPCZoneIdentifier": "{{ vpc_zone_identifier }}"{% endif %}{% if has_context %},
  "Context": "{{ context }}"{% endif %},
  "Tags": [
    {% for tag in base_tags %}
    {
      "Key": "{{ tag.key }}",
      "Value": "{{ tag.value }}",
      "PropagateAtLaunch": true,
      "ResourceId": "{{ asg_name }}",
      "ResourceType": "auto-scaling-group"
    }{% if not loop.last or has_custom_tags %},{% endif %}
    {% endfor %}{% if has_custom_tags %},
    {% for tag in custom_tags %}
    {
      "Key": "{{ tag.key }}",
      "Value": "{{ tag.value }}",
      "PropagateAtLaunch": true,
      "ResourceId": "{{ asg_name }}",
      "ResourceType": "auto-scaling-group"
    }{% if not loop.last %},{% endif %}
    {% endfor %}{% endif %}
  ]
}
