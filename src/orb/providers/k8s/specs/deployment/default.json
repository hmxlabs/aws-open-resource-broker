{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "{{ resource_name }}",
    "namespace": "{{ namespace }}",
    "labels": {{ labels | tojson }}{% if has_annotations %},
    "annotations": {{ annotations | tojson }}{% endif %}
  },
  "spec": {
    "replicas": {{ replicas }},
    "selector": {
      "matchLabels": {
        "{{ label_prefix }}/request-id": "{{ request_id }}",
        "{{ label_prefix }}/provider-api": "{{ provider_api }}"
      }
    },
    "template": {
      "metadata": {
        "labels": {{ labels | tojson }}{% if has_annotations %},
        "annotations": {{ annotations | tojson }}{% endif %}
      },
      "spec": {
        "restartPolicy": "Always",
        {% if has_service_account %}"serviceAccountName": "{{ service_account }}",{% endif %}
        {% if has_runtime_class %}"runtimeClassName": "{{ runtime_class }}",{% endif %}
        {% if has_node_selector %}"nodeSelector": {{ node_selector | tojson }},{% endif %}
        {% if has_tolerations %}"tolerations": {{ tolerations | tojson }},{% endif %}
        {% if has_image_pull_secret %}"imagePullSecrets": [{"name": "{{ image_pull_secret }}"}],{% endif %}
        {% if has_volumes %}"volumes": {{ volumes | tojson }},{% endif %}
        "containers": [
          {
            "name": "orb",
            "image": "{{ image }}"{% if has_command %},
            "command": {{ command | tojson }}{% endif %}{% if has_args %},
            "args": {{ args | tojson }}{% endif %}{% if has_env %},
            "env": {{ env | tojson }}{% endif %}{% if has_volume_mounts %},
            "volumeMounts": {{ volume_mounts | tojson }}{% endif %}{% if has_resource_requests or has_resource_limits %},
            "resources": {
              {% if has_resource_requests %}"requests": {{ resource_requests | tojson }}{% if has_resource_limits %},{% endif %}{% endif %}
              {% if has_resource_limits %}"limits": {{ resource_limits | tojson }}{% endif %}
            }{% endif %}
          }
        ]
      }
    }
  }
}
